{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/session_start_context.py",
            "timeout": 30,
            "statusMessage": "Loading idkWidk context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/user_prompt_submit_intake.py",
            "timeout": 30,
            "statusMessage": "Checking for idkWidk intake signals"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/pre_tool_use_safety.py",
            "timeout": 30,
            "statusMessage": "Checking command safety"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${PLUGIN_ROOT}/hooks/stop_handoff_guard.py",
            "timeout": 30,
            "statusMessage": "Checking idkWidk handoff and verification"
          }
        ]
      }
    ]
  }
}
